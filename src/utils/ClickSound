const base = import.meta.env.BASE_URL;

const audioPath1 = (name) => `${base}/sound/${name}`;
const clickSound1 = new Audio(audioPath1("Click-2.mp3"));

export const playClick1 = () => {
    clickSound1.currentTime = 0;
    clickSound1.play();
};

